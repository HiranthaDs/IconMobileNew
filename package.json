{
  "name": "icon-mobile-lan-erp",
  "version": "3.0.0",
  "private": true,
  "description": "Offline browser asset build for the ICON MOBILE FastAPI/SQLite LAN application",
  "scripts": {
    "vendor": "node scripts/vendor-assets.mjs",
    "css": "tailwindcss -c tailwind.config.cjs -i assets/tailwind-input.css -o assets/app.css --minify",
    "build": "npm run vendor && npm run css",
    "check:html": "node scripts/check-html.mjs"
  },
  "dependencies": {
    "@babel/standalone": "7.24.7",
    "@fontsource/inter": "5.0.18",
    "@fontsource/jetbrains-mono": "5.0.20",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "tailwindcss": "3.4.17"
  },
  "engines": {
    "node": ">=18"
  }
}
