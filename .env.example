# Change these before using the application on a shared network.
POS_PASSWORD=ICONM@2026
ADMIN_PASSWORD=ADMIN@2026
WHOLESALE_PASSWORD=ADMIN@WS

# Optional. If unset, the backend creates a private persistent signing secret.
# SESSION_SECRET=replace-with-a-long-random-secret

ICON_HOST=0.0.0.0
ICON_PORT=8000
ICON_BACKUP_DIR=_backups
SESSION_HOURS=12
MAX_REQUEST_BYTES=5242880
MAX_RESTORE_BYTES=536870912

# --- backend/ (Supabase-backed scaffold, separate service on its own port) ---
# Project Settings -> API in the Supabase dashboard.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_KEY=replace-with-your-service-role-key
# Project Settings -> Database -> Connection string -> URI. Used only to run
# schema DDL (CREATE TABLE IF NOT EXISTS ...) on server startup.
SUPABASE_DB_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
